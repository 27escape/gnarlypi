#!/usr/bin/env bash
# ----------------------------------------------------------------------------

# for your user, create an entry in your crontab
# @reboot /home/$USER/gnarlypi/be_gnarly

# ----------------------------------------------------------------------------

source "$HOME/gnarlypi/setenv.sh"


# ----------------------------------------------------------------------------
function kill_processes() {
  local proc_name="$1"

  # ask pgrep for matches, then filter out our own PID
  local pids
  # We don't want to kill the script itself, so exclude our PID
  pids=$(pgrep -f "$proc_name" | grep -v -x "$$" || true)

  if [ -n "$pids" ]; then
    # echo "Killing processes for '$proc_name' (excluding $$): $pids"
    kill $pids 2>/dev/null || echo "Failed to kill some processes for '$proc_name'"
  # else
    # echo "No processes found for $proc_name (or only the current script)"
  fi
}

# ----------------------------------------------------------------------------

cd "$BIN_PATH" || (echo "cannot find dir $BIN_PATH" && exit 1)

SELF=$(basename "$0")

kill_processes "gnarly" 
kill_processes "gnarly" 

# remove any previous log files
rm -f /tmp/gnarlypi* 2>/dev/null

if [ -z "$USER" ]; then
  echo "USER not set, must be running from cron, setting to LOGNAME $LOGNAME" >> $GNARLY_ERR_LOG
  export USER=$LOGNAME
fi

# this will start up other apps as required, inc the status displays
"./gnarlypi"  >> $GNARLY_ERR_LOG 2>&1
