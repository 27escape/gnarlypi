# ----------------------------------------------------------------------------

UPDATE_KEEP_ALIVE = 1
BLOCK_SIZE = 1024 * 1024 * 1024
ONE_MINUTE = 60

PAGE_HEIGHT = 24 ;

TIME_BOX = 1
COPY_BOX = 2
DISK_BOX = 3
MSG_BOX = 4

MIN_BOX_WIDTH = 40  # minimum terminal width we support

TIME_WIDTH = MIN_BOX_WIDTH
BOX_WIDTH = MIN_BOX_WIDTH

TIME_HEIGHT = 3
COPY_HEIGHT = 4
DISK_HEIGHT = 4
MSG_HEIGHT = 9

TIME_X = 0
COPY_X = 0
DISK_X = 0
MSG_X = 0

# need 1 line between them all
BOX_V_SPACE = 1
TIME_Y = 0
COPY_Y = BOX_V_SPACE + TIME_HEIGHT
DISK_Y = BOX_V_SPACE + COPY_Y + COPY_HEIGHT
MSG_Y = BOX_V_SPACE + DISK_Y + DISK_HEIGHT
MSG_TEXT_WIDTH = BOX_WIDTH - 2

# progress bar sizing - bar length is derived from the available width
# rather than fixed, so bars fit correctly from MIN_BOX_WIDTH upwards
MIN_BAR_LENGTH = 6
MAX_BAR_LENGTH = 50
# fixed characters around the bar in "{prefix} [{bar}] {percent}% {suffix}":
# " [" (2) + "] " (2) + percent, always 3 chars with decimals=0 (3) + "% " (2)
BAR_FIXED_OVERHEAD = 9

# Display update throttling to prevent lag - only refresh the terminal
# (the expensive part) at most this often. addstr() calls are cheap and
# stay unthrottled; only the physical refresh() is rate-limited.
LAST_DISPLAY_UPDATE_TIME = 0
DISPLAY_UPDATE_MIN_INTERVAL = 0.1  # minimum 100ms between terminal refreshes

# ----------------------------------------------------------------------------
def empty_line(width=None):
    if width is None:
        width = MSG_TEXT_WIDTH
    return " ".center(width, " ")


# ----------------------------------------------------------------------------
# Initialize variables, these need to be globals where used
gStdscr = None
time_area = empty_line()  # single line
file_copy_area = [empty_line(), empty_line()]  # individual file, all files
disk_status_area = [empty_line(), empty_line()]  # SD, HD
msg_area = [
    empty_line(),
    empty_line(),
    empty_line(),
    empty_line(),
    empty_line(),
    empty_line(),
    empty_line(),
]  # 5 lines
last_status_time = 0

# last known data for the two MQTT-driven panels, so a terminal resize can
# redraw them at the new width without waiting on the next MQTT message
last_copydata = None
last_devicedata = None

# Guards all curses drawing calls and layout globals, since curses is not
# thread-safe and both the MQTT subscription thread and the main curses
# loop touch them. Reentrant so the resize handler (which recomputes
# layout under the lock) can still call update_display() itself.
display_lock = threading.RLock()


# ----------------------------------------------------------------------------
def progressBar (prefix, iteration, total, length = 50, suffix = '', decimals = 0, fill = '█'):
    """
    Call in a loop to create terminal progress bar
    @params:
        prefix      - Optional  : prefix string (Str)
        iteration   - Required  : current iteration (Int)
        total       - Required  : total iterations (Int)
        length      - Optional  : character length of bar (Int)
        suffix      - Optional  : suffix string (Str)
        decimals    - Optional  : positive number of decimals in percent complete (Int)
        fill        - Optional  : bar fill character (Str)
    """
    percent = "0"
    try:
        percent = ("{0:>3." + str(decimals) + "f}").format(100 * (iteration / float(total)))
        filledLength = int(length * iteration // total)
    except:
        percent = "  0"    # right justify :)
        filledLength = 0
    bar = fill * filledLength + ' ' * (length - filledLength)
    return f'{prefix} [{bar}] {percent}% {suffix}'


# ----------------------------------------------------------------------------
# work out how long a progress bar can be so the whole line fits within
# MSG_TEXT_WIDTH, given the fixed prefix/suffix text around it
def compute_bar_length(prefix, suffix=''):
    length = MSG_TEXT_WIDTH - len(prefix) - len(suffix) - BAR_FIXED_OVERHEAD
    return max(MIN_BAR_LENGTH, min(MAX_BAR_LENGTH, length))


# ----------------------------------------------------------------------------
def draw_box(x, y, width, height, title, color_pair):
    # chgat() explicitly sets the color attribute across the given cells,
    # instead of relying on how ncurses chose to paint runs of plain space
    # characters (some terminals don't honor the "background color erase"
    # optimization ncurses uses there, leaving blank runs un-colored).
    attr = curses.color_pair(color_pair)
    gStdscr.addstr(y, x, "┌" + "─" * (width - 2) + "┐", attr)
    gStdscr.chgat(y, x, width, attr)
    for i in range(y + 1, y + height - 1):
        gStdscr.addstr(i, x, "│" + " " * (width - 2) + "│", attr)
        gStdscr.chgat(i, x, width, attr)
    gStdscr.addstr(
        y + height - 1, x, "└" + "─" * (width - 2) + "┘", attr
    )
    gStdscr.chgat(y + height - 1, x, width, attr)
    gStdscr.addstr(y, x + 2, title[:max(0, width - 3)], attr)


# ----------------------------------------------------------------------------
# this will perform the relatively slow refresh() call for all the other
# small addstr() writes to the display; it should only be called after all
# the other draw calls have been performed.
# 'force' bypasses throttling for things that must appear immediately (errors,
# resize redraws).
def update_display(force=False):
    global LAST_DISPLAY_UPDATE_TIME

    with display_lock:
        # Draw boxes for each area with different colors
        draw_box(TIME_X, TIME_Y, TIME_WIDTH, TIME_HEIGHT, "Time", TIME_BOX)
        draw_box(COPY_X, COPY_Y, BOX_WIDTH, COPY_HEIGHT, "File Copy Progress", COPY_BOX)
        draw_box(DISK_X, DISK_Y, BOX_WIDTH, DISK_HEIGHT, "Disk Status", DISK_BOX)
        draw_box(MSG_X, MSG_Y, BOX_WIDTH, MSG_HEIGHT, "Messages", MSG_BOX)

        gStdscr.addstr(TIME_Y + 1, 1, time_area, curses.color_pair(TIME_BOX))
        gStdscr.chgat(TIME_Y + 1, 1, TIME_WIDTH - 2, curses.color_pair(TIME_BOX))

        for i, line in enumerate(file_copy_area):
            gStdscr.addstr(COPY_Y + 1 + i, 1, line, curses.color_pair(COPY_BOX))
            gStdscr.chgat(COPY_Y + 1 + i, 1, BOX_WIDTH - 2, curses.color_pair(COPY_BOX))
        for i, line in enumerate(disk_status_area):
            gStdscr.addstr(DISK_Y + 1 + i, 1, line, curses.color_pair(DISK_BOX))
            gStdscr.chgat(DISK_Y + 1 + i, 1, BOX_WIDTH - 2, curses.color_pair(DISK_BOX))
        for i, line in enumerate(msg_area):
            gStdscr.addstr(MSG_Y + 1 + i, 1, line, curses.color_pair(MSG_BOX))
            gStdscr.chgat(MSG_Y + 1 + i, 1, BOX_WIDTH - 2, curses.color_pair(MSG_BOX))

        current_time = time.time()
        if force or (current_time - LAST_DISPLAY_UPDATE_TIME) >= DISPLAY_UPDATE_MIN_INTERVAL:
            gStdscr.refresh()
            LAST_DISPLAY_UPDATE_TIME = current_time


# ----------------------------------------------------------------------------

def signal_handler(sig, frame):
    global gStdscr
    logger.warn('Exit due to CTRL+C or signal received')
    
    # Explicitly restore the terminal state before hard-exiting
    try:
        curses.nocbreak()
        curses.echo()
        if gStdscr is not None:
            gStdscr.keypad(False)
        curses.endwin()
    except Exception as e:
        logger.debug(f"Terminal cleanup error: {e}")
        
    print("\nExiting Gnarly Status...")
    # os._exit immediately terminates all threads, preventing MQTT loops from hanging
    os._exit(0)


# ----------------------------------------------------------------------------


def cls():
    global msg_area, file_copy_area, disk_status_area
    
    # clear all display areas
    with display_lock:
        for i, line in enumerate(msg_area):
            msg_area[i] = empty_line()
        for i, line in enumerate(file_copy_area):
            file_copy_area[i] = empty_line()
        for i, line in enumerate(disk_status_area):
            disk_status_area[i] = empty_line()

    update_display()


# ----------------------------------------------------------------------------
def clr_line(line=0):
    # global msg_area
    if line < (MSG_HEIGHT-2):
      msg_area[line] = empty_line()
      update_display()


# ----------------------------------------------------------------------------
def print_msg(txt, line=2):
    # global msg_area
    if line < (MSG_HEIGHT-2):
      # truncate to fit, and pad to the full width so shorter messages fully
      # overwrite whatever longer text (at a possibly wider layout) was there
      msg_area[line] = txt[:MSG_TEXT_WIDTH].ljust(MSG_TEXT_WIDTH)
      update_display()


# ----------------------------------------------------------------------------
# use local system time so the clock keeps ticking even when no MQTT
# keepalives are arriving (e.g. while a copy is in progress)
def show_time(seconds=None):
    global time_area
    if seconds is None:
        seconds = time.time()
    time_area = datetime.fromtimestamp(seconds).strftime("%X").center(TIME_WIDTH - 2, ' ')
    update_display()

